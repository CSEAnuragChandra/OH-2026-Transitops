generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ----------------------------------------------------------------------
// ENUMS
// ----------------------------------------------------------------------

enum Role {
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
  DRIVER
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

// ----------------------------------------------------------------------
// MODELS
// ----------------------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Hashed via bcryptjs
  name      String
  role      Role
  
  // Link for driver auto-provisioning
  driver    Driver?  

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vehicle {
  id                 String           @id @default(cuid())
  registrationNumber String           @unique
  name               String
  type               String
  maxLoadCapacity    Float
  odometer           Float            @default(0)
  acquisitionCost    Float
  status             VehicleStatus    @default(AVAILABLE)

  // Relationships
  trips              Trip[]
  maintenanceLogs    MaintenanceLog[]
  fuelLogs           FuelLog[]

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model Driver {
  id              String       @id @default(cuid())
  name            String
  licenseNumber   String       @unique
  licenseCategory String
  licenseExpiry   DateTime
  contactNumber   String
  safetyScore     Int          @default(100)
  status          DriverStatus @default(AVAILABLE)

  // Relates to User for Driver Portal login (Auto-provisioning)
  userId          String?      @unique 
  user            User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Relationships
  trips           Trip[]

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Trip {
  id              String     @id @default(cuid())
  code            String     @unique // e.g., TR001
  source          String
  destination     String
  cargoWeight     Float
  plannedDistance Float
  status          TripStatus @default(DRAFT)
  
  // Populated on completion
  finalOdometer   Float?
  fuelConsumed    Float?

  // Relationships
  vehicleId       String?
  vehicle         Vehicle?   @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  
  driverId        String?
  driver          Driver?    @relation(fields: [driverId], references: [id], onDelete: SetNull)
  
  expenses        Expense[]
  fuelLogs        FuelLog[]  // Optional link for fuel logged during dispatch

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model MaintenanceLog {
  id          String   @id @default(cuid())
  description String
  cost        Float
  date        DateTime
  status      String   // "In Shop" | "Completed"

  // Relationships
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FuelLog {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  liters    Float
  cost      Float

  // Relationships
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  
  tripId    String?  
  trip      Trip?    @relation(fields: [tripId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Expense {
  id          String   @id @default(cuid())
  toll        Float    @default(0)
  other       Float    @default(0)

  // Relationships
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}